# ── .env.example ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# The real .env is gitignored and never committed.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────

# Weights & Biases — https://wandb.ai/settings
WANDB_API_KEY=

# W&B project name (can leave as-is)
WANDB_PROJECT=solar-flare-prediction

# JSOC / DRMS (for SHARP magnetogram access)
# Register at: http://jsoc.stanford.edu/ajax/register_email.html
JSOC_EMAIL=

# Optional: local path overrides
# Useful if you store raw data on an external drive
# DATA_DIR=/Volumes/MyDrive/solar-flare/data
